NUVEMSHOP_STORE_ID=<seu_store_id>
NUVEMSHOP_ACCESS_TOKEN=<seu_access_token>
NUVEMSHOP_API_BASE_URL=https://api.nuvemshop.com.br/2025-03
REDIS_HOST=localhost
REDIS_PORT=6379
PORT=3001
LOG_LEVEL=info
IDEMPOTENCY_TTL_SECONDS=300

# Rate limiter — calibrado para o Leaky Bucket da Nuvemshop
# Documentação: https://tiendanube.github.io/api-documentation/intro#rate-limiting
# Plano padrão: bucket de 40 req, drain de 2 req/s
# Planos Next/Evolution: multiplicador de 10x (use 400 e 1200)
RATE_LIMIT_MAX_TOKENS=40      # capacidade do bucket (burst)
RATE_LIMIT_REFILL_RATE=120    # req/min → 120/60 = 2 req/s (drain real da API)
