NUVEMSHOP_STORE_ID=<seu_store_id>
NUVEMSHOP_ACCESS_TOKEN=<seu_access_token>
NUVEMSHOP_API_BASE_URL=https://api.nuvemshop.com.br/2025-03
REDIS_HOST=localhost
REDIS_PORT=6379
PORT=3001
LOG_LEVEL=info
LOKI_HOST=                       # ex: http://localhost:3100 — ativa envio direto ao Grafana Loki
IDEMPOTENCY_TTL_SECONDS=300

# Rate limiter — calibrado para o Leaky Bucket da Nuvemshop
# Documentação: https://tiendanube.github.io/api-documentation/intro#rate-limiting
# Limite máximo da plataforma: 500 req/s — NUNCA configurar acima deste valor.
# Para operação conservadora use valores menores (ex: 300 req/s = RATE_LIMIT_REFILL_RATE=18000).
RATE_LIMIT_MAX_TOKENS=500     # capacidade do bucket (burst = 1 s de throughput @ 500 req/s)
RATE_LIMIT_REFILL_RATE=30000  # req/min → 30000/60 = 500 req/s (limite máximo da API)
