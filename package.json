{
  "name": "pco-nuvemshop",
  "version": "1.0.0",
  "description": "Middleware SAP → Nuvemshop — Fashion Corp",
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "start":            "node src/app.js",
    "worker":           "node src/worker.js",
    "dev":              "nodemon src/app.js",
    "test":             "jest --runInBand --forceExit",
    "test:unit":        "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:e2e":         "NUVEMSHOP_TESTING_REAL=true jest --config jest.e2e.config.js --runInBand --forceExit"
  },
  "dependencies": {
    "bullmq":  "^5.0.0",
    "dotenv":  "^16.0.0",
    "express": "^4.18.0",
    "ioredis": "^5.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "ioredis-mock": "^8.0.0",
    "jest":         "^29.0.0",
    "nock":         "^14.0.0",
    "nodemon":      "^3.0.0",
    "supertest":    "^6.3.0"
  }
}
